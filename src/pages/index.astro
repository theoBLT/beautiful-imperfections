---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryCard from '../components/CategoryCard.astro';

// Placeholder categories — will be replaced with real ones from content
const categories = [
  {
    number: '01',
    title: 'Objects',
    entryCount: 0,
    quote: 'Every plastic wrap tells a story of love, or at least of caution.',
    accentColor: 'terracotta',
  },
  {
    number: '02',
    title: 'Civic',
    entryCount: 0,
    quote: 'The distance between intention and implementation is where poetry lives.',
    accentColor: 'dusty-blue',
  },
  {
    number: '03',
    title: 'Typography',
    entryCount: 0,
    quote: 'When every font is available, why not use all of them at once?',
    accentColor: 'sage',
  },
  {
    number: '04',
    title: 'Ingenuity',
    entryCount: 0,
    quote: 'Necessity mothers invention; budget constraints raise it.',
    accentColor: 'ochre',
  },
  {
    number: '05',
    title: 'Urbanism',
    entryCount: 0,
    quote: 'The city was planned; the city had other plans.',
    accentColor: 'terracotta',
  },
  {
    number: '06',
    title: 'Culture',
    entryCount: 0,
    quote: 'Tradition is just peer pressure from the beautifully dead.',
    accentColor: 'dusty-blue',
  },
];
---

<BaseLayout>
  <!-- Hero section -->
  <section class="max-w-6xl mx-auto px-6 pt-16 pb-12 md:pt-24 md:pb-16">
    <div class="max-w-2xl">
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-medium leading-tight mb-6">
        Beautiful<br />
        <em class="text-terracotta">Imperfections</em>
      </h1>
      <p class="text-ink/60 text-lg md:text-xl leading-relaxed max-w-lg">
        A field guide to the beautifully botched — documenting design quirks,
        ad-hoc engineering, and charming oddities found in everyday life.
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-6xl mx-auto px-6">
    <div class="border-t border-border"></div>
  </div>

  <!-- Categories grid -->
  <section class="max-w-6xl mx-auto px-6 py-12 md:py-16">
    <div class="flex items-center justify-between mb-10">
      <h2 class="font-sans text-xs tracking-[0.2em] uppercase text-ink/40">
        Browse by Category
      </h2>
      <span class="font-sans text-xs text-ink/30">
        {categories.length} categories
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {categories.map(cat => (
        <CategoryCard
          number={cat.number}
          title={cat.title}
          entryCount={cat.entryCount}
          quote={cat.quote}
          accentColor={cat.accentColor}
        />
      ))}
    </div>
  </section>

  <!-- Bottom quote -->
  <section class="max-w-6xl mx-auto px-6 pb-16">
    <div class="border-t border-border pt-10">
      <blockquote class="font-serif italic text-lg text-ink/40 max-w-lg">
        &ldquo;The crack is where the light gets in — and sometimes where
        the motorcycle parks.&rdquo;
      </blockquote>
    </div>
  </section>
</BaseLayout>
