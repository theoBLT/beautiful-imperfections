---
const navItems = [
  { label: 'Index', href: '/' },
  { label: 'Archive', href: '/archive' },
  { label: 'About', href: '/about' },
];
---

<header class="sticky top-0 z-40 bg-cream/90 backdrop-blur-sm border-b border-border">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Wordmark -->
    <a href="/" class="font-serif italic text-xl text-ink hover:text-terracotta transition-colors">
      Beautiful Imperfections
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navItems.map(item => (
        <a
          href={item.href}
          class="text-sm font-sans tracking-wide text-ink/60 hover:text-ink transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2 -mr-2"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block w-5 h-px bg-ink transition-transform origin-center" id="bar-1"></span>
      <span class="block w-5 h-px bg-ink transition-opacity" id="bar-2"></span>
      <span class="block w-5 h-px bg-ink transition-transform origin-center" id="bar-3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="md:hidden hidden border-t border-border bg-cream"
  >
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-3">
      {navItems.map(item => (
        <a
          href={item.href}
          class="text-sm font-sans tracking-wide text-ink/60 hover:text-ink transition-colors py-1"
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar-1');
  const bar2 = document.getElementById('bar-2');
  const bar3 = document.getElementById('bar-3');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));

    if (isOpen) {
      bar1?.classList.add('rotate-45', 'translate-y-[4px]');
      bar2?.classList.add('opacity-0');
      bar3?.classList.add('-rotate-45', '-translate-y-[4px]');
    } else {
      bar1?.classList.remove('rotate-45', 'translate-y-[4px]');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-rotate-45', '-translate-y-[4px]');
    }
  });
</script>
