---
interface Photo {
  src: string;
  caption?: string;
  featured?: boolean;
}

interface Props {
  photos: Photo[];
  heroSrc?: string;
}

const { photos, heroSrc } = Astro.props;

// Filter out the hero image from gallery if it's the same file
const galleryPhotos = heroSrc
  ? photos.filter(p => !p.src.endsWith(heroSrc.split('/').pop() || ''))
  : photos;

if (galleryPhotos.length === 0) return;
---

<section class="mt-16 pt-12 border-t border-border">
  <div class="flex items-center gap-3 mb-8">
    <div class="w-8 h-px bg-border"></div>
    <h2 class="font-sans text-xs tracking-[0.2em] uppercase text-ink/40">
      More Examples
    </h2>
    <div class="flex-1 h-px bg-border"></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="gallery-grid">
    {galleryPhotos.map((photo, index) => (
      <figure
        class="group cursor-pointer"
        data-lightbox-trigger={index}
        data-photo-src={photo.src}
        data-photo-caption={photo.caption || ''}
      >
        <div class="overflow-hidden rounded-sm border border-border bg-placeholder aspect-[4/3]">
          <img
            src={photo.src}
            alt={photo.caption || `Example ${index + 1}`}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </div>
        {photo.caption && (
          <figcaption class="mt-2 text-xs text-ink/40 font-sans leading-relaxed">
            {photo.caption}
          </figcaption>
        )}
      </figure>
    ))}
  </div>
</section>

{/* Lightbox */}
<div
  id="lightbox"
  class="lightbox-overlay hidden"
>
  <button
    class="absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center text-white/70 hover:text-white transition-colors"
    id="lightbox-close"
    aria-label="Close"
  >
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <button
    class="absolute left-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center text-white/50 hover:text-white transition-colors"
    id="lightbox-prev"
    aria-label="Previous"
  >
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
    </svg>
  </button>

  <button
    class="absolute right-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center text-white/50 hover:text-white transition-colors"
    id="lightbox-next"
    aria-label="Next"
  >
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
    </svg>
  </button>

  <div class="flex items-center justify-center w-full h-full p-8 sm:p-16">
    <img
      src=""
      alt=""
      class="max-w-full max-h-full object-contain"
      id="lightbox-img"
    />
  </div>

  <div class="absolute bottom-4 left-0 right-0 text-center">
    <p class="text-sm text-white/60 font-sans px-8" id="lightbox-caption"></p>
  </div>
</div>

<script>
  // Build photos array from DOM data attributes
  const triggers = document.querySelectorAll('[data-lightbox-trigger]');
  const photos: { src: string; caption: string }[] = [];
  triggers.forEach(el => {
    photos.push({
      src: (el as HTMLElement).dataset.photoSrc || '',
      caption: (el as HTMLElement).dataset.photoCaption || '',
    });
  });

  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lightbox-caption');
  let currentIndex = 0;

  function openLightbox(index: number) {
    currentIndex = index;
    updateLightbox();
    lightbox?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function updateLightbox() {
    const photo = photos[currentIndex];
    if (lbImg) {
      lbImg.src = photo.src;
      lbImg.alt = photo.caption;
    }
    if (lbCaption) lbCaption.textContent = photo.caption;
  }

  function next() {
    currentIndex = (currentIndex + 1) % photos.length;
    updateLightbox();
  }

  function prev() {
    currentIndex = (currentIndex - 1 + photos.length) % photos.length;
    updateLightbox();
  }

  // Click triggers
  triggers.forEach(el => {
    el.addEventListener('click', () => {
      openLightbox(parseInt(el.getAttribute('data-lightbox-trigger') || '0'));
    });
  });

  document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
  document.getElementById('lightbox-prev')?.addEventListener('click', prev);
  document.getElementById('lightbox-next')?.addEventListener('click', next);

  // Click overlay background to close
  lightbox?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target === lightbox || (!target.closest('button') && !target.closest('img'))) {
      closeLightbox();
    }
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (lightbox?.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') next();
    if (e.key === 'ArrowLeft') prev();
  });
</script>
